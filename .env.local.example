# 複製這個檔案為 .env.local，填入你的金鑰（本機開發用）
# 部署到 Vercel 時，改在 Vercel 後台 Settings → Environment Variables 設定

# 謄本辨識用（Anthropic API 金鑰，向 console.anthropic.com 申請）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# 名單收集用（Google Apps Script 網址，見 google-apps-script.js 說明）
GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/xxxxxxxx/exec
